# ============================================================
# 环境变量配置模板
# 复制此文件为 .env 并填写你的配置
# ============================================================

# 服务端口
PORT=7621

# 管理面板密码
ADMIN_PWD=your_admin_password

# CORS 域名（生产环境必填，填你的域名）
CORS_ORIGIN=https://your-domain.com

# ---- 智谱 AI（看板娘聊天用） ----
GLM_API_KEY=your_glm_api_key
GLM_MODEL=glm-4.5-air

# ---- 网易云音乐 Cookie（音乐播放器用，可选） ----
# 扫码登录后自动生成，格式: MUSIC_U=xxxx
NETEASE_COOKIE=
